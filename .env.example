# Django Settings
SECRET_KEY=django-insecure-example-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Email settings
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=your_email@gmail.com

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Frontend config
FRONTEND_URL=http://localhost:3000

# Database Configuration
# Set to 'postgres' to use PostgreSQL (default for Docker setup), or 'sqlite' for local SQLite
DATABASE_TYPE=sqlite
SQLITE_DB_NAME=db.sqlite3

# PostgreSQL settings (used when DATABASE_TYPE=postgres)
POSTGRES_DB=visulara_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432
